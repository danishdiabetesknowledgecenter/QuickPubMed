### General variables
VITE_ABOUT_AI_URL="/../om-nempubmed"
VITE_CLIENT_NAME=""

### Variables for NLM (only myncbishare needed - API key is handled server-side)
VITE_MY_NCBI_SHARE=""

### Variables for API Proxy (handles OpenAI and NLM API calls)
VITE_API_PROXY_URL="https://your-domain.com/backend"
VITE_DOMAIN=""
VITE_USE_AI="true"
VITE_USE_AI_SUMMARIZER="true"
VITE_LONG_ABSTRACT_LENGTH_LIMIT="5000"
VITE_WAIT_TIME_DISCLAIMER_DELAY="5000"
VITE_RUNTIME_CONTENT_CACHE_TTL_MS="300000"
VITE_THEME_CACHE_TTL_MS="300000"

### Mesh/NLM tuning (performance and resilience)
VITE_MESH_NLM_TIMEOUT_MS="10000"
VITE_MESH_NLM_RETRY_ATTEMPTS="2"
VITE_MESH_VALIDATION_CONCURRENCY="2"
VITE_MESH_VALIDATION_CACHE_LIMIT="500"
VITE_MESH_VALIDATION_CACHE_TTL_MS="900000"

### Variables for Unpaywall
VITE_UNPAYWALL_URL="https://api.unpaywall.org/v2"
VITE_UNPAYWALL_EMAIL=""